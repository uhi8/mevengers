# MEVengers Environment Variables

# ─── Unichain RPC ─────────────────────────────────────────────────
UNICHAIN_RPC_URL=https://mainnet.unichain.org
UNICHAIN_SEPOLIA_RPC_URL=https://sepolia.unichain.org

# ─── Deployment ───────────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY
AI_AGENT_PRIVATE_KEY=0xYOUR_AI_AGENT_PRIVATE_KEY
AI_AGENT_URI=ipfs://mevengers-ai-agent

# ─── Deployed Addresses (fill in after running Deploy.s.sol) ───────
MEV_HOOK_ADDRESS=0x
MEV_AGENT_REGISTRY_ADDRESS=0x
MEV_INSURANCE_FUND_ADDRESS=0x
MEV_SENTINEL_ADDRESS=0x   # On Reactive Network
UNICHAIN_POOL_MANAGER_ADDRESS=0x

# ─── Reactive Network ─────────────────────────────────────────────
REACTIVE_RPC_URL=https://rpc.reactive.network
REACTIVE_AUTO_SUBSCRIBE=false

# ─── Telegram Bot ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
ALICE_PRIVATE_KEY=0x
BOB_PRIVATE_KEY=0x

# ─── Relayer ──────────────────────────────────────────────────────
RELAYER_RECOVERY_BLOCK_WINDOW=5000

# ─── AI Agent ─────────────────────────────────────────────────────
PREEMPTIVE_SCORE_THRESHOLD=75
